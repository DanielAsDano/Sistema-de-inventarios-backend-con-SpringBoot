spring.application.name=Sistema de inventarios
# conexion a mysql
spring.datasource.url=jdbc:mysql://localhost:tu_puerto/inventario_db?createDatabaseIfNotExist=true
spring.datasource.username=tu_username
spring.datasource.password=tu_contraseña
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

#configurar el patron log
logging.pattern.console=[%thread] %-5level: %logger - %msg%n
#configurar el nivel de log
logging.level.root=INFO